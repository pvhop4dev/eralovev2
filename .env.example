# ============================================
# Eralove — Environment Variables Template
# Copy this file: cp .env.example .env
# ============================================

# ── App ──────────────────────────────────────
APP_NAME=Eralove API
DEBUG=true
LOG_LEVEL=DEBUG

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eralove:eralove_dev@localhost:5432/eralove

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-this-in-production-immediately
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS S3 (MinIO for local dev) ─────────────
AWS_S3_BUCKET=eralove-media
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000

# ── Claude AI ────────────────────────────────
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# ── Email (Mailpit for local dev) ────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@eralove.com

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend (Next.js) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_S3_BUCKET_URL=http://localhost:9000/eralove-media
